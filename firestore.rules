rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────
    // Only the owner can read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Saved Spots (subcollection of users) ─────────────────────
    match /users/{uid}/savedSpots/{spotId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Spot Notes (subcollection of users) ──────────────────────
    match /users/{uid}/spotNotes/{spotId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Refresh credits (subcollections of users) ─────────────────
    // destRefreshes: how many times the user has force-refreshed a trip destination
    // cityPreviews:  how many times the user has refreshed a dateless city preview
    // Both are owner-only — no other user or public can read/write them.
    match /users/{uid}/destRefreshes/{destId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/cityPreviews/{slug} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Trips ────────────────────────────────────────────────────
    // Owners can read/write; collaborators can read/write; public/token trips are readable by anyone
    match /trips/{tripId} {
      allow read: if (request.auth != null && request.auth.uid == resource.data.userId)
                  || resource.data.isPublic == true
                  || (request.auth != null && request.auth.uid in resource.data.get('collaboratorUids', []))
                  || resource.data.get('shareToken', null) != null;
      allow write: if request.auth != null
        && (request.auth.uid == resource.data.userId
            || request.auth.uid in resource.data.get('collaboratorUids', []));
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // ── Destinations ─────────────────────────────────────────────
    // Owners can read/write; destinations are publicly readable (no PII beyond userId)
    // Public read is gated at the trip level — getTripPublic checks isPublic first.
    match /destinations/{destId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
    }

    // ── City Spots (cache) ───────────────────────────────────────
    // Publicly readable (AI-researched data, no PII)
    match /citySpots/{city}/spots/{spotId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── City Events (recurring events, Glasgow-gated) ────────────
    // Publicly readable; only signed-in users can write (server-side research)
    match /cityEvents/{city} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cityEvents/{city}/events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── City Deep Spots (comprehensive single-category cache) ────
    // Same policy as citySpots — AI data, no PII
    match /cityDeepSpots/{cacheId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cityDeepSpots/{cacheId}/spots/{spotId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Day Plans ────────────────────────────────────────────────
    // Owners can read/write; collaborators on the parent trip can also write.
    // Public read — gated at trip level via isPublic.
    match /dayPlans/{planId} {
      allow read: if true;
      allow write: if request.auth != null
        && (request.auth.uid == resource.data.userId
            || request.auth.uid in get(/databases/$(database)/documents/trips/$(resource.data.tripId)).data.get('collaboratorUids', []));
      allow create: if request.auth != null
        && (request.auth.uid == request.resource.data.userId
            || request.auth.uid in get(/databases/$(database)/documents/trips/$(request.resource.data.tripId)).data.get('collaboratorUids', []));
    }

    // ── Day Plan Spots ───────────────────────────────────────────
    // Publicly readable (no PII — just spot IDs + time slots)
    match /dayPlanSpots/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── City Passes (curated, read-only for clients) ─────────────
    match /cityPasses/{city} {
      allow read: if request.auth != null;
      allow write: if false; // seeded manually via admin/console
    }

    // ── City Templates (trip templates per city) ─────────────────
    // Publicly readable; any signed-in user can save their itinerary as a template.
    match /cityTemplates/{city}/templates/{templateId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.authorId;
      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.authorId;
    }

    // ── Spot Reviews ─────────────────────────────────────────────
    // Aggregate doc (avgRating, count) is publicly readable.
    // Individual reviews: publicly readable; only the author can write.
    match /spotReviews/{spotId} {
      allow read: if true;
      allow write: if false; // written via client batch alongside subcollection
    }
    match /spotReviews/{spotId}/reviews/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
